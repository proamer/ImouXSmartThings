# ─── Server ───────────────────────────────────────────
PORT=3000
NODE_ENV=development
PUBLIC_BASE_URL=

# ─── Imou Open Platform ──────────────────────────────
# Register at https://open.imoulife.com to get these credentials
IMOU_APP_ID=your_imou_app_id
IMOU_APP_SECRET=your_imou_app_secret

# Imou API Base URL (choose by region)
#   Global:     https://openapi.easy4ip.com/openapi
#   Singapore:  https://openapi-sg.easy4ip.com/openapi
#   Frankfurt:  https://openapi-fk.easy4ip.com/openapi
IMOU_API_BASE=https://openapi.easy4ip.com/openapi

# Optional RTSP stream source for SmartThings native camera playback.
# Prefer per-camera env vars such as:
#   IMOU_RTSP_URL_9L109B5PBV3BE8D_0=rtsp://user:pass@host:554/path
# Or use a template with {deviceId} and {channelId} placeholders:
#   IMOU_RTSP_URL_TEMPLATE=rtsp://user:pass@192.168.1.10:554/cam/realmonitor?channel={channelId}&subtype=0
IMOU_RTSP_URL_TEMPLATE=

# ─── SmartThings ─────────────────────────────────────
# From SmartThings Developer Workspace after registering Schema Connector
ST_CLIENT_ID=your_smartthings_client_id
ST_CLIENT_SECRET=your_smartthings_client_secret

# Webhook verification secret (optional, for request signature validation)
WEBHOOK_SECRET=your_webhook_secret
ST_MANUFACTURER_NAME=PROAMER
ST_MODEL_NAME=proamer

# Use the Device Profile ID from SmartThings Developer Center for custom profiles.
# Leave ST_USE_CUSTOM_PROFILE=false for the native SmartThings camera UI.
ST_USE_CUSTOM_PROFILE=false
ST_DEVICE_PROFILE_ID=
ST_DEVICE_HANDLER_TYPE=c2c-camera-rtsp-1

# ─── OAuth2 Server (for SmartThings Schema) ─────────
# These credentials are for YOUR OAuth2 server.
# Generate them with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# Use these values when registering the Schema Connector in SmartThings Developer Workspace.
OAUTH_CLIENT_ID=your_oauth_client_id
OAUTH_CLIENT_SECRET=your_oauth_client_secret
OAUTH_SCOPE=imou:cameras
