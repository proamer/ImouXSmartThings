              "raw": "{\n  \"system\": {\n    \"ver\": \"1.0\",\n    \"appId\": \"{{IMOU_APP_ID}}\",\n    \"sign\": \"{{SIGN}}\",\n    \"time\": {{TIME}},\n    \"nonce\": \"{{NONCE}}\"\n  },\n  \"id\": \"live-001\",\n  \"params\": {\n    \"token\": \"{{IMOU_ACCESS_TOKEN}}\",\n    \"deviceId\": \"{{device_id}}\",\n    \"channelId\": \"{{channel_id}}\",\n    \"streamId\": 0\n  }\n}"
